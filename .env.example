# Membro v2 — Environment Variables
# Bu dosyayı kopyalayıp .env olarak kaydet: cp .env.example .env

# ─── PostgreSQL ────────────────────────────────────────────────
POSTGRES_PASSWORD=membro_dev_pass
# Tam bağlantı URL'i — asyncpg driver ile
DATABASE_URL=postgresql+asyncpg://membro_user:membro_dev_pass@localhost:5432/membro_db

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# ─── Neo4j ─────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=membro_dev_pass

# ─── Milvus ────────────────────────────────────────────────────
MILVUS_URI=http://milvus:19530

# ─── Cloudflare AI Gateway ─────────────────────────────────────
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_GATEWAY_ID=membro-gateway
# CF AI Gateway Auth Token — Cloudflare Dashboard > AI Gateway > Settings > Auth Token
CF_AIG_TOKEN=your_cloudflare_aig_token_here

# NOT: CF_AI_GATEWAY_BASE_URL env'den okunmaz — backend config.py'de
# cf_account_id + cf_gateway_id'den otomatik hesaplanır (@property).

# ─── Provider API Anahtarları ──────────────────────────────────
# CF Unified Billing / BYOK aktif — provider API anahtarları burada
# tanımlanmaz; Cloudflare Dashboard > AI Gateway > Settings > Provider Keys.

# ─── App ───────────────────────────────────────────────────────
APP_ENV=development
APP_DOMAIN=localhost
FRONTEND_URL=http://localhost:3000

# ─── Faz 4: LiveKit WebRTC Ses Altyapısı ───────────────────────
# Geliştirme: docker-compose içindeki self-hosted LiveKit
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretkey-membro-local-dev001

# ─── Faz 5: LangSmith Gözlemlenebilirlik ───────────────────────
# LangSmith UI: https://smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=membro-production
# Trace'leri aktif etmek için true yap (geliştirmede false bırakılabilir)
LANGSMITH_TRACING=false

# ─── Faz 5: Güvenlik Limitleri ─────────────────────────────────
# Tenant başına dakikalık maksimum istek sayısı
RATE_LIMIT_PER_MINUTE=60
# LLM'e gönderilecek maksimum kullanıcı mesajı uzunluğu (karakter)
INPUT_MAX_LENGTH=4000

# ─── Next.js ───────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL kasıtlı boş — browser göreceli /api/ kullanır, Nginx proxy eder
# NEXT_PUBLIC_API_URL=
# Docker içi Next.js → backend iç ağ adresi (NEXT_PUBLIC_ değil, browser'a açılmaz)
BACKEND_URL=http://backend:8000
NEXT_PUBLIC_APP_DOMAIN=localhost
