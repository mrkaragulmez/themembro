# Membro v2 — Environment Variables
# Bu dosyayı kopyalayıp .env olarak kaydet: cp .env.example .env

# ─── PostgreSQL ────────────────────────────────────────────────
POSTGRES_PASSWORD=membro_dev_pass

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# ─── Neo4j ─────────────────────────────────────────────────────
NEO4J_PASSWORD=membro_dev_pass
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j

# ─── Milvus ────────────────────────────────────────────────────
MILVUS_URI=http://milvus:19530

# ─── Cloudflare AI Gateway ─────────────────────────────────────
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_GATEWAY_ID=membro-gateway
CF_AI_GATEWAY_BASE_URL=https://gateway.ai.cloudflare.com/v1/${CF_ACCOUNT_ID}/${CF_GATEWAY_ID}
# CF AI Gateway Auth Token — Cloudflare Dashboard > AI Gateway > Settings > Auth Token
CF_AIG_TOKEN=your_cloudflare_aig_token_here

# ─── Provider API Anahtarları ─────────────────────────────────────
# CF Unified Billing / BYOK aktif — provider API anahtarları burada
# tanımlanmaz; Cloudflare Dashboard > AI Gateway > API Keys yönetilir.
# (Dashboard: https://dash.cloudflare.com > AI Gateway > Settings > Provider Keys)

# ─── App ────────────────────────────────────────────────────────
APP_ENV=development
APP_DOMAIN=localhost
FRONTEND_URL=http://localhost:3000

# ─── Next.js ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_DOMAIN=localhost
